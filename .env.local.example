# ─── TIENDA NUBE ───────────────────────────────────────────────
# Panel: vematel.com.ar → Configuración → Aplicaciones → Crear app privada
# Permisos: read_products, write_products, read_orders, write_orders
TIENDANUBE_STORE_ID=7143771
TIENDANUBE_ACCESS_TOKEN=tu_access_token_aqui

# ─── FLEXUS ────────────────────────────────────────────────────
# Solicitar a soporte de Flexus: URL de API + credenciales
FLEXUS_API_URL=https://api.flexus.com.ar/v1
FLEXUS_API_KEY=tu_api_key_flexus

# ─── NEON (PostgreSQL serverless) ──────────────────────────────
# neon.tech → New Project → Connection Details
# DATABASE_URL: usar la conexión "pooled" (con -pooler en el host) para runtime
# DATABASE_URL_UNPOOLED: conexión directa para prisma migrate
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ─── SYNC ──────────────────────────────────────────────────────
# Clave secreta para autorizar llamadas al endpoint de sync (cron + manual)
SYNC_SECRET=genera_una_clave_aleatoria_larga

# ─── APP ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://tu-app.vercel.app
